<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FSMNavigator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Couleurs système -->
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryVariant">@color/bg_mid</item>
        <item name="colorOnPrimary">@color/bg_deep</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_mid</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Navigation Drawer -->
        <item name="drawerArrowStyle">@style/DrawerArrowStyle</item>
    </style>

    <style name="DrawerArrowStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="color">@color/accent_cyan</item>
    </style>

    <!-- Style TabLayout glassmorphism -->
    <style name="GlassTabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabSelectedTextColor">@color/accent_cyan</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabIndicatorColor">@color/accent_cyan</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabIndicatorHeight">2dp</item>
    </style>

    <!-- Style bouton principal -->
    <style name="GlassButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/accent_cyan</item>
        <item name="android:textColor">@color/bg_deep</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Style bouton outline -->
    <style name="GlassButtonOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_cyan</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>
</resources>