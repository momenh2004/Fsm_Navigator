<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FSMNavigator" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="android:fontFamily">@font/plex_sans</item>
    </style>

    <!-- ───── Typographie réutilisable ───── -->
    <style name="Text" />

    <style name="Text.TitleXL">
        <item name="android:fontFamily">@font/space_grotesk</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_title_xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.025</item>
        <item name="android:lineSpacingMultiplier">1.02</item>
    </style>

    <style name="Text.Sheet">
        <item name="android:fontFamily">@font/space_grotesk</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_sheet</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="Text.Section">
        <item name="android:fontFamily">@font/space_grotesk</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">@dimen/text_section</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Body">
        <item name="android:fontFamily">@font/plex_sans</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Sub">
        <item name="android:fontFamily">@font/plex_sans</item>
        <item name="android:textSize">@dimen/text_sub</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <style name="Text.Mono">
        <item name="android:fontFamily">@font/plex_mono</item>
        <item name="android:textSize">@dimen/text_mono</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- ───── Bouton primaire : plein cyan, texte sombre ───── -->
    <style name="Widget.FSM.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_height">@dimen/btn_primary_h</item>
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:fontFamily">@font/plex_sans</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ───── Bouton contour cyan ───── -->
    <style name="Widget.FSM.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/btn_outline_h</item>
        <item name="strokeColor">@color/accent_line</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:fontFamily">@font/plex_sans</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_button</item>
    </style>

    <!-- ───── Lien texte ───── -->
    <style name="Widget.FSM.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">@font/plex_sans</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- ───── Champ souligné (pas de carte) ───── -->
    <style name="Widget.FSM.Input" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">none</item>
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxStrokeWidth">0dp</item>
    </style>

    <!-- ───── Chip filtre ───── -->
    <style name="Widget.FSM.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/bg_deep</item>
        <item name="chipStrokeColor">@color/stroke_white</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipCornerRadius">@dimen/radius_pill</item>
        <item name="android:fontFamily">@font/plex_sans</item>
    </style>

    <!-- ───── Styles hérités (compatibilité écrans non encore redessinés) ───── -->
    <style name="DrawerArrowStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="color">@color/accent</item>
    </style>

    <style name="GlassTabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabSelectedTextColor">@color/accent</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabIndicatorColor">@color/accent</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabIndicatorHeight">2dp</item>
    </style>

    <style name="GlassButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="GlassButtonOutline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/accent</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="GlassButtonSmall" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <style name="GlassButtonOutlineSmall" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/accent</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:minHeight">40dp</item>
    </style>
</resources>
