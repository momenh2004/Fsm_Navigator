<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="36dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#00D4FF"
                android:background="@drawable/bg_glass_card"
                android:contentDescription="Retour"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Espace Admin"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Accès restreint • OTP requis"
                    android:textColor="#607080"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Badge admin -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pmr_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="⚙ ADMIN"
                android:textColor="#00D4FF"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Carte Glass -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#12FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Étape 1 : Email admin -->
                <LinearLayout
                    android:id="@+id/layoutStep1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email administrateur"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_glass_input"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="20dp">

                        <TextView android:layout_width="20dp" android:layout_height="20dp"
                            android:text="✉" android:textColor="#607080" android:textSize="14sp"
                            android:gravity="center"/>

                        <EditText
                            android:id="@+id/etAdminEmail"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:background="@null"
                            android:hint="admin@fsm.rnu.tn"
                            android:textColorHint="#607080"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:inputType="textEmailAddress"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnRequestOtp"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_button_cyan"
                        android:text="Envoyer le code OTP"
                        android:textColor="#1A1A2E"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"/>
                </LinearLayout>

                <!-- Étape 2 : Code OTP -->
                <LinearLayout
                    android:id="@+id/layoutStep2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Un code OTP a été envoyé à votre email"
                        android:textColor="#607080"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="20dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Code OTP"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_glass_card_cyan"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="20dp">

                        <TextView android:layout_width="20dp" android:layout_height="20dp"
                            android:text="🔑" android:textSize="14sp" android:gravity="center"
                            android:layout_marginEnd="12dp"/>

                        <EditText
                            android:id="@+id/etOtpCode"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="123456"
                            android:textColorHint="#607080"
                            android:textColor="#00D4FF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:inputType="numberPassword"
                            android:gravity="center"
                            android:letterSpacing="0.2"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnVerifyOtp"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_button_cyan"
                        android:text="Vérifier le code"
                        android:textColor="#1A1A2E"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvResendOtp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Renvoyer le code"
                        android:textColor="#607080"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Progress -->
                <ProgressBar
                    android:id="@+id/progressAdmin"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="#00D4FF"
                    android:visibility="gone"
                    android:layout_marginTop="12dp"/>

                <!-- Erreur -->
                <TextView
                    android:id="@+id/tvAdminError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF4B6E"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>