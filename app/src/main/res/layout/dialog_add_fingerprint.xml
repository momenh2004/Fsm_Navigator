<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_add_fingerprint.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText android:id="@+id/etDialogBssid"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="BSSID (ex: cc:b2:55:91:37:d0)"
        android:inputType="text"
        android:layout_marginBottom="10dp"/>

    <EditText android:id="@+id/etDialogSsid"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="SSID (nom du réseau WiFi)"
        android:inputType="text"
        android:layout_marginBottom="10dp"/>

    <EditText android:id="@+id/etDialogRssi"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="RSSI moyen (ex: -65.5)"
        android:inputType="numberDecimal|numberSigned"/>
</LinearLayout>