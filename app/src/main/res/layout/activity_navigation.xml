<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- AppBar commune aux 2 modes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#00D4FF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Retour"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Navigation"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvNavDestination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choisissez votre destination"
                android:textColor="#00D4FF"
                android:textSize="12sp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnStopNav"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FF4B6E"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Arrêter"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- MODE RECHERCHE                                      -->
    <!-- ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutSearch"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Barre de recherche -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_glass_input"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:text="🔍"
                android:textSize="14sp"
                android:gravity="center"/>

            <EditText
                android:id="@+id/etSearchDest"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@null"
                android:hint="Rechercher une salle, un amphithéâtre..."
                android:textColorHint="#607080"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:singleLine="true"
                android:inputType="text"/>
        </LinearLayout>

        <!-- Chargement -->
        <ProgressBar
            android:id="@+id/progressSearch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="#00D4FF"
            android:visibility="gone"
            android:layout_marginTop="24dp"/>

        <!-- Message vide -->
        <TextView
            android:id="@+id/tvSearchEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aucun résultat"
            android:textColor="#607080"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"/>

        <!-- Liste des destinations -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerDest"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="16dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- MODE NAVIGATION                                     -->
    <!-- ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutNavigation"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Canvas navigation -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <com.fsm.navigator.navigation.NavigationView
                android:id="@+id/navigationView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/progressNav"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="#00D4FF"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- Card instruction -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardNavInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="#CC1A1A2E"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvNavStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Localisation en cours..."
                    android:textColor="#607080"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvNavIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_glass_card_cyan"
                        android:text="→"
                        android:textColor="#00D4FF"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNavInstruction"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Calcul de l'itinéraire..."
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:id="@+id/tvNavDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#00D4FF"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>