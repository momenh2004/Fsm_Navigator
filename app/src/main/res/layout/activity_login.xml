<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- Logo / Titre -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="40dp">

            <!-- Cercle logo -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="20dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_avatar"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="FSM"
                    android:textColor="#1A1A2E"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FSM Navigator"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Navigation intelligente du campus"
                android:textColor="#607080"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Carte Glass Login -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#12FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connexion"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connectez-vous à votre compte FSM"
                    android:textColor="#607080"
                    android:textSize="13sp"
                    android:layout_marginBottom="24dp"/>

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#B0BEC5"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_glass_input"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:text="✉"
                        android:textColor="#607080"
                        android:textSize="14sp"
                        android:gravity="center"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@null"
                        android:hint="votre@email.com"
                        android:textColorHint="#607080"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"/>
                </LinearLayout>

                <!-- Mot de passe -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mot de passe"
                    android:textColor="#B0BEC5"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_glass_input"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:text="🔒"
                        android:textColor="#607080"
                        android:textSize="13sp"
                        android:gravity="center"/>

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@null"
                        android:hint="••••••••"
                        android:textColorHint="#607080"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:singleLine="true"/>

                    <ImageButton
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:tint="#607080"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Afficher mot de passe"/>
                </LinearLayout>

                <!-- Erreur -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF4B6E"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <!-- Switch PMR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mode accessibilité (PMR)"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchPmr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/accent_cyan"
                        app:trackTint="#2600D4FF"/>
                </LinearLayout>

                <!-- Bouton Login -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_button_cyan"
                    android:text="Se connecter"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="16dp"/>

                <!-- Progress -->
                <ProgressBar
                    android:id="@+id/progressLogin"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="@color/accent_cyan"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"/>

                <!-- Inscription -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pas de compte ? "
                        android:textColor="#607080"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S'inscrire"
                        android:textColor="#00D4FF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Continuer sans compte -->
                <TextView
                    android:id="@+id/tvGuest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Continuer sans compte"
                    android:textColor="#607080"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Accès admin -->
        <TextView
            android:id="@+id/tvAdminAccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="40dp"
            android:text="⚙ Espace administrateur"
            android:textColor="#404A58"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</ScrollView>