<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_screen_gradient">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_h"
                android:paddingEnd="@dimen/screen_h"
                android:paddingTop="40dp"
                android:paddingBottom="130dp">

                <!-- Salutation + avatar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Text.Sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:text="Bonjour," />

                        <TextView
                            android:id="@+id/greetingName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/space_grotesk"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_name"
                            android:letterSpacing="-0.025"
                            android:text="Étudiant" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/avatarBtn"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_avatar"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/avatarInitial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/space_grotesk"
                            android:textFontWeight="600"
                            android:textColor="@color/on_accent"
                            android:textSize="20sp"
                            android:text="É" />
                    </FrameLayout>
                </LinearLayout>

                <!-- BARRE HÉRO -->
                <LinearLayout
                    android:id="@+id/searchHero"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/search_hero_h"
                    android:layout_marginTop="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_hero"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/accent"
                        android:contentDescription="Rechercher" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="15dp"
                        android:fontFamily="@font/plex_sans"
                        android:textColor="@color/text_muted"
                        android:textSize="17sp"
                        android:text="Où allez-vous ?" />
                </LinearLayout>

                <!-- Grille 2×2 raccourcis (2 rangées LinearLayout) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:orientation="horizontal">
                    <include layout="@layout/item_shortcut" android:id="@+id/shortcut1" />
                    <include layout="@layout/item_shortcut" android:id="@+id/shortcut2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include layout="@layout/item_shortcut" android:id="@+id/shortcut3" />
                    <include layout="@layout/item_shortcut" android:id="@+id/shortcut4" />
                </LinearLayout>

                <!-- Section récents -->
                <TextView
                    style="@style/Text.Section"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="38dp"
                    android:layout_marginBottom="6dp"
                    android:text="Récemment consultés" />

                <LinearLayout
                    android:id="@+id/recentList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Accès carte campus -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccederCarte"
                    style="@style/Widget.FSM.Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_outline_h"
                    android:layout_marginTop="28dp"
                    android:text="Accéder à la carte du campus"
                    app:icon="@drawable/ic_navigate"
                    app:iconGravity="textStart"
                    app:iconTint="@color/accent" />

            </LinearLayout>
        </ScrollView>

        <!-- FAB étendu Naviguer -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabNaviguer"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/fab_ext_h"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="26dp"
            android:text="Naviguer"
            android:textColor="@color/on_accent"
            android:textAllCaps="false"
            android:fontFamily="@font/plex_sans"
            android:textFontWeight="600"
            android:textSize="16sp"
            app:backgroundTint="@color/accent"
            app:cornerRadius="@dimen/radius_pill"
            app:icon="@drawable/ic_navigate"
            app:iconTint="@color/on_accent"
            app:iconGravity="textStart" />

    </FrameLayout>

    <!-- Navigation Drawer (swipe depuis le bord) -->
    <include layout="@layout/nav_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
