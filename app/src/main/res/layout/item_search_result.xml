<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#12FFFFFF"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Icône catégorie -->
        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginEnd="14dp">
            <View
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_glass_card_cyan"/>
            <ImageView
                android:id="@+id/ivPoiIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_compass"
                android:tint="#00D4FF"
                android:contentDescription="Icône"/>
        </FrameLayout>

        <!-- Infos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPoiName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salle 301"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:id="@+id/tvPoiDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bloc 3 • RDC"
                android:textColor="#607080"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvPoiCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_filter_unselected"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="Salles"
                android:textColor="#B0BEC5"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Bouton Y aller -->
        <LinearLayout
            android:id="@+id/btnNavigate"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:background="@drawable/bg_button_cyan"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginStart="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Y aller"
                android:textColor="#1A1A2E"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>