<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient">

        <!-- AppBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp">

            <ImageButton
                android:id="@+id/btnHamburger"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#00D4FF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="Profil"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Avatar Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#12FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="28dp">

                        <!-- Avatar cercle -->
                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_marginBottom="16dp">
                            <View android:layout_width="80dp" android:layout_height="80dp"
                                android:background="@drawable/bg_avatar"/>
                            <TextView
                                android:id="@+id/tvAvatarInitial"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="H"
                                android:textColor="#1A1A2E"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:gravity="center"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Étudiant"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvProfileEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="email@fsm.rnu.tn"
                            android:textColor="#607080"
                            android:textSize="13sp"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/tvProfileRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_filter_selected"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:text="Étudiant"
                            android:textColor="#00D4FF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Historique -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#12FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Historique"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvClearHistory"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Effacer"
                                android:textColor="#00D4FF"
                                android:textSize="12sp"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutHistoryItems"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <TextView
                            android:id="@+id/tvHistoryEmpty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:text="Aucune recherche récente"
                            android:textColor="#607080"
                            android:textSize="13sp"
                            android:visibility="visible"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Actions -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#12FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <!-- Modifier mot de passe -->
                        <LinearLayout
                            android:id="@+id/btnChangePassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView android:layout_width="28dp" android:layout_height="28dp"
                                android:text="🔑" android:textSize="16sp" android:gravity="center"
                                android:layout_marginEnd="14dp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Modifier le mot de passe"
                                android:textColor="#B0BEC5" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="›" android:textColor="#00D4FF" android:textSize="18sp"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="#0FFFFFFF" android:layout_marginStart="58dp"/>

                        <!-- Déconnexion -->
                        <LinearLayout
                            android:id="@+id/btnLogout"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView android:layout_width="28dp" android:layout_height="28dp"
                                android:text="↩" android:textSize="16sp" android:gravity="center"
                                android:textColor="#FF4B6E" android:layout_marginEnd="14dp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Déconnexion"
                                android:textColor="#FF4B6E" android:textSize="14sp"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="#0FFFFFFF" android:layout_marginStart="58dp"/>

                        <!-- Supprimer compte -->
                        <LinearLayout
                            android:id="@+id/btnDeleteAccount"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView android:layout_width="28dp" android:layout_height="28dp"
                                android:text="🗑" android:textSize="16sp" android:gravity="center"
                                android:layout_marginEnd="14dp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Supprimer mon compte"
                                android:textColor="#FF4B6E" android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Accès admin (caché) -->
                <TextView
                    android:id="@+id/tvAdminAccess"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:text="⚙ Espace administrateur"
                    android:textColor="#404A58"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Champs cachés pour compatibilité -->
                <TextView android:id="@+id/tvProfileFullName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:visibility="gone"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <include layout="@layout/nav_drawer" android:layout_gravity="start"/>

</androidx.drawerlayout.widget.DrawerLayout>