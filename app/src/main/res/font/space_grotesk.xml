<?xml version="1.0" encoding="utf-8"?>
<!--
  Place les .ttf dans res/font/ (noms en minuscules + underscore).
  Télécharge Space Grotesk depuis Google Fonts :
    space_grotesk_regular.ttf  (400)
    space_grotesk_medium.ttf   (500)
    space_grotesk_semibold.ttf (600)
    space_grotesk_bold.ttf     (700)
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font android:fontStyle="normal" android:fontWeight="400" android:font="@font/space_grotesk_regular"
        app:fontStyle="normal" app:fontWeight="400" app:font="@font/space_grotesk_regular" />
    <font android:fontStyle="normal" android:fontWeight="500" android:font="@font/space_grotesk_medium"
        app:fontStyle="normal" app:fontWeight="500" app:font="@font/space_grotesk_medium" />
    <font android:fontStyle="normal" android:fontWeight="600" android:font="@font/space_grotesk_semibold"
        app:fontStyle="normal" app:fontWeight="600" app:font="@font/space_grotesk_semibold" />
    <font android:fontStyle="normal" android:fontWeight="700" android:font="@font/space_grotesk_bold"
        app:fontStyle="normal" app:fontWeight="700" app:font="@font/space_grotesk_bold" />
</font-family>
