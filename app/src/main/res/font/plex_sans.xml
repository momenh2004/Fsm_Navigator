<?xml version="1.0" encoding="utf-8"?>
<!--
  IBM Plex Sans (Google Fonts) dans res/font/ :
    ibm_plex_sans_light.ttf    (300)
    ibm_plex_sans_regular.ttf  (400)
    ibm_plex_sans_medium.ttf   (500)
    ibm_plex_sans_semibold.ttf (600)
    ibm_plex_sans_bold.ttf     (700)
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font android:fontStyle="normal" android:fontWeight="300" android:font="@font/ibm_plex_sans_light"
        app:fontStyle="normal" app:fontWeight="300" app:font="@font/ibm_plex_sans_light" />
    <font android:fontStyle="normal" android:fontWeight="400" android:font="@font/ibm_plex_sans_regular"
        app:fontStyle="normal" app:fontWeight="400" app:font="@font/ibm_plex_sans_regular" />
    <font android:fontStyle="normal" android:fontWeight="500" android:font="@font/ibm_plex_sans_medium"
        app:fontStyle="normal" app:fontWeight="500" app:font="@font/ibm_plex_sans_medium" />
    <font android:fontStyle="normal" android:fontWeight="600" android:font="@font/ibm_plex_sans_semibold"
        app:fontStyle="normal" app:fontWeight="600" app:font="@font/ibm_plex_sans_semibold" />
    <font android:fontStyle="normal" android:fontWeight="700" android:font="@font/ibm_plex_sans_bold"
        app:fontStyle="normal" app:fontWeight="700" app:font="@font/ibm_plex_sans_bold" />
</font-family>
