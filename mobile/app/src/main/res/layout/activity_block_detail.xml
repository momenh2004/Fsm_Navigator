<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_deep">

        <!-- Plan plein écran -->
        <com.fsm.navigator.view.BlocDetailView
            android:id="@+id/blocDetailView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Pill flottante haut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/pill_h"
            android:layout_gravity="top"
            android:layout_margin="16dp"
            android:background="@drawable/bg_pill_floating"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary"
                android:contentDescription="Retour" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/tvBlocTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:textFontWeight="600"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:text="Bloc" />

                <TextView
                    android:id="@+id/tvBlocSubtitle"
                    style="@style/Text.Mono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plan intérieur" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnHamburger"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_menu"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary"
                android:contentDescription="Menu" />
        </LinearLayout>

        <!-- Sélecteur d'étage (sous la pill) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="88dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnRDC"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="RDC"
                android:textColor="@color/on_accent"
                android:textSize="13sp"
                android:fontFamily="@font/plex_sans"
                android:textFontWeight="600"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnEtage1"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_chip_inactive"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="1ᵉʳ étage"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/plex_sans"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Card salle info (bottom sheet style, GONE par défaut) -->
        <LinearLayout
            android:id="@+id/cardSalleInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_sheet"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="20dp"
            android:visibility="gone">

            <!-- Zone de balayage -->
            <LinearLayout
                android:id="@+id/handleDismiss"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="20dp"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="@color/stroke_white" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSalleNom"
                style="@style/Text.Sheet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salle" />

            <TextView
                android:id="@+id/tvSalleDetails"
                style="@style/Text.Sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavigerSalle"
                style="@style/Widget.FSM.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_primary_h"
                android:layout_marginTop="20dp"
                android:text="Naviguer →" />
        </LinearLayout>

    </FrameLayout>

    <!-- Navigation Drawer -->
    <include layout="@layout/nav_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
