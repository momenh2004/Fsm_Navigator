<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_gradient">

    <!-- titre, aligné gauche -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:paddingTop="64dp">

        <TextView
            style="@style/Text.TitleXL"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bon retour." />

        <TextView
            style="@style/Text.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:maxWidth="260dp"
            android:lineSpacingMultiplier="1.45"
            android:text="Connectez-vous pour retrouver vos trajets et favoris." />
    </LinearLayout>

    <!-- formulaire poussé vers le bas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:paddingBottom="30dp">

        <!-- champ e-mail souligné -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/emailLayout"
            style="@style/Widget.FSM.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Adresse e-mail">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_input"
                android:fontFamily="@font/plex_sans" />
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="1.5dp"
            android:background="@color/divider_white" android:layout_marginBottom="28dp" />

        <!-- champ mot de passe -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/pwLayout"
            style="@style/Widget.FSM.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mot de passe"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_muted">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_input"
                android:fontFamily="@font/plex_sans" />
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="1.5dp"
            android:background="@color/divider_white" android:layout_marginBottom="28dp" />

        <!-- ligne PMR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">
            <ImageView
                android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_accessible"
                app:tint="@color/text_muted"
                android:contentDescription="PMR" />
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView style="@style/Text.Body" android:textFontWeight="500"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="15sp" android:text="Itinéraires accessibles" />
                <TextView style="@style/Text.Sub"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12.5sp" android:text="Priorité rampes &amp; ascenseurs" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchPmr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- erreur -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/danger"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- bouton primaire cyan -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/Widget.FSM.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_primary_h"
            android:layout_marginTop="4dp"
            android:text="Se connecter" />

        <!-- progression -->
        <ProgressBar
            android:id="@+id/progressLogin"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/accent"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- liens -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/tvGuest"
                style="@style/Widget.FSM.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Continuer sans compte" />
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/tvRegister"
                style="@style/Widget.FSM.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Créer un compte" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
