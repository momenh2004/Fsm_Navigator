<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_screen_gradient">

        <!-- Barre haut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="@dimen/screen_h"
            android:paddingTop="40dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btnHamburger"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_menu"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary"
                android:contentDescription="Menu" />

            <TextView
                style="@style/Text.Section"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Mon profil" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40dp">

                <!-- Avatar + nom + email + badge rôle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingStart="@dimen/screen_h"
                    android:paddingEnd="@dimen/screen_h"
                    android:paddingTop="24dp"
                    android:paddingBottom="32dp">

                    <!-- Avatar 96dp -->
                    <FrameLayout
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@drawable/bg_avatar"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:id="@+id/tvAvatarInitial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/space_grotesk"
                            android:textFontWeight="700"
                            android:textColor="@color/on_accent"
                            android:textSize="36sp"
                            android:text="É" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvProfileName"
                        style="@style/Text.Section"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Nom Prénom" />

                    <TextView
                        android:id="@+id/tvProfileFullName"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="invisible"
                        android:text="" />

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        style="@style/Text.Sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="email@fsm.rnu.tn" />

                    <!-- Badge rôle -->
                    <TextView
                        android:id="@+id/tvProfileRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_badge"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:fontFamily="@font/plex_mono"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:text="Étudiant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_white" />

                <!-- Favoris (section dépliable) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/btnToggleFavoris"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/screen_h"
                        android:paddingEnd="@dimen/screen_h"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            style="@style/Text.Body"
                            android:textFontWeight="600"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mes favoris" />
                        <ImageView
                            android:id="@+id/chevronFavoris"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:rotation="90"
                            app:tint="@color/text_muted" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutFavorisItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/screen_h"
                        android:paddingEnd="@dimen/screen_h"
                        android:visibility="visible">

                        <ProgressBar
                            android:id="@+id/progressFavoris"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:indeterminateTint="@color/accent"
                            android:visibility="gone"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvFavorisEmpty"
                            style="@style/Text.Sub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:text="Aucun favori enregistré"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_white" />

                <!-- Historique (section dépliable) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/btnToggleHistory"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/screen_h"
                        android:paddingEnd="@dimen/screen_h"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            style="@style/Text.Body"
                            android:textFontWeight="600"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Historique" />
                        <ImageView
                            android:id="@+id/chevronHistory"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:rotation="90"
                            app:tint="@color/text_muted" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutHistoryItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/screen_h"
                        android:paddingEnd="@dimen/screen_h"
                        android:visibility="visible">

                        <TextView
                            android:id="@+id/tvHistoryEmpty"
                            style="@style/Text.Sub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:text="Aucun trajet récent"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvClearHistory"
                            style="@style/Text.Sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/accent"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:text="Effacer l'historique"
                            android:visibility="gone"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_white" />

                <!-- Changer mot de passe -->
                <LinearLayout
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/screen_h"
                    android:paddingEnd="@dimen/screen_h"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        style="@style/Text.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Changer le mot de passe" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_muted" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_white" />

                <!-- Se déconnecter -->
                <LinearLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/screen_h"
                    android:paddingEnd="@dimen/screen_h"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plex_sans"
                        android:textColor="@color/danger"
                        android:textSize="16sp"
                        android:text="Se déconnecter" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_white" />

                <!-- Supprimer le compte -->
                <LinearLayout
                    android:id="@+id/btnDeleteAccount"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/screen_h"
                    android:paddingEnd="@dimen/screen_h"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plex_sans"
                        android:textColor="@color/danger"
                        android:textSize="15sp"
                        android:text="Supprimer mon compte" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- Navigation Drawer -->
    <include layout="@layout/nav_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
